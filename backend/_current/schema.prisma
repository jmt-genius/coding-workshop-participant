datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-py"
  recursive_type_depth = 5
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   // HR, MANAGER, EMPLOYEE
  profile      EmployeeProfile?
  leadTeams    Team[]   @relation("TeamLead")
  reportedBugs Bug[]    @relation("BugReporter")
  resolvedBugs Bug[]    @relation("BugResolver")
  assignedBugs Bug[]    @relation("BugOwner")
  openedTickets Ticket[] @relation("TicketOpener")
  closedTickets Ticket[] @relation("TicketCloser")
  assignedTickets Ticket[] @relation("TicketAssignee")
  commits      Commit[]  @relation("UserCommits")
  managedProjects Project[] @relation("ProjectManager")
  projectHistory  ProjectHistory[] @relation("UserProjectHistory")
  performanceReviews PerformanceReview[] @relation("UserReviews")
  givenReviews    PerformanceReview[] @relation("Reviewer")
  createdAt    DateTime @default(now())
}

model Team {
  id           String   @id @default(uuid())
  name         String   @unique
  leadId       String
  lead         User     @relation("TeamLead", fields: [leadId], references: [id])
  members      EmployeeProfile[]
  achievements Achievement[]
  projects     Project[]
  createdAt    DateTime @default(now())
}

model EmployeeProfile {
  id             String @id @default(uuid())
  userId         String @unique
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId         String?
  team           Team?  @relation(fields: [teamId], references: [id])
  projectId      String?
  project        Project? @relation("CurrentProject", fields: [projectId], references: [id])
  
  // High-level metadata
  specialization String @default("Generalist")
  joinedAt       DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // HR metrics
  performanceRating Float?   // 1.0 to 5.0
  promotionReady    Boolean  @default(false)
  attritionRisk     String   @default("LOW") // LOW, MEDIUM, HIGH

  employeeSkills    EmployeeSkill[]
  trainings         Training[]
}

model Commit {
  id        String   @id @default(uuid())
  hash      String   @unique
  message   String
  impact    Float    @default(1.0)
  userId    String
  user      User     @relation("UserCommits", fields: [userId], references: [id])
  projectId String?
  project   Project? @relation("ProjectCommits", fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}

model Ticket {
  id           String   @id @default(uuid())
  title        String
  status       String   // OPEN, CLOSED
  difficulty   Float    @default(1.0)
  
  // Relations
  projectId    String?
  project      Project? @relation("ProjectTickets", fields: [projectId], references: [id])
  
  assigneeId   String?
  assignee     User?    @relation("TicketAssignee", fields: [assigneeId], references: [id])
  
  openedById   String
  openedBy     User     @relation("TicketOpener", fields: [openedById], references: [id])
  
  closedById   String?
  closedBy     User?    @relation("TicketCloser", fields: [closedById], references: [id])

  closedAt     DateTime?
  createdAt    DateTime @default(now())
}

model Bug {
  id           String   @id @default(uuid())
  title        String
  severity     String   // LOW, MEDIUM, HIGH, CRITICAL
  status       String   @default("OPEN")
  
  // Relations
  projectId    String?
  project      Project? @relation("ProjectBugs", fields: [projectId], references: [id])
  
  reporterId   String
  reporter     User     @relation("BugReporter", fields: [reporterId], references: [id])
  
  ownerId      String?  // Current assignee
  owner        User?    @relation("BugOwner", fields: [ownerId], references: [id])
  
  resolverId   String?  // Who fixed it
  resolver     User?    @relation("BugResolver", fields: [resolverId], references: [id])

  createdAt    DateTime @default(now())
}

model Achievement {
  id          String   @id @default(uuid())
  title       String
  description String
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id])
  date        DateTime @default(now())
  icon        String   @default("emoji_events")
}

model Project {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  status          String   @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD
  requiredSkills  String[] // Array of strings representing required tech stacks
  managerId       String
  manager         User     @relation("ProjectManager", fields: [managerId], references: [id])
  
  teamId          String?
  team            Team?    @relation(fields: [teamId], references: [id])
  
  milestones       Milestone[] @relation("ProjectMilestones")
  
  currentEngineers EmployeeProfile[] @relation("CurrentProject")
  history          ProjectHistory[]
  commits          Commit[]          @relation("ProjectCommits")
  tickets          Ticket[]          @relation("ProjectTickets")
  bugs             Bug[]             @relation("ProjectBugs")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ProjectHistory {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserProjectHistory", fields: [userId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role        String
  startDate   DateTime
  endDate     DateTime?
}

model EmployeeSkill {
  id          String   @id @default(uuid())
  skillName   String
  proficiency Float    // 1.0 (Beginner) to 5.0 (Expert)
  profileId   String
  profile     EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Training {
  id             String   @id @default(uuid())
  name           String
  description    String?
  completionDate DateTime
  profileId      String
  profile        EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model PerformanceReview {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserReviews", fields: [userId], references: [id], onDelete: Cascade)
  reviewerId  String
  reviewer    User     @relation("Reviewer", fields: [reviewerId], references: [id])
  rating      Float    // 1.0 to 5.0
  comments    String?
  date        DateTime @default(now())
}
model Milestone {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation("ProjectMilestones", fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  duration    String?  // e.g. "3 months"
  impact      Float    @default(1.0)
  isAchieved  Boolean  @default(false)
  date        DateTime @default(now())
}
